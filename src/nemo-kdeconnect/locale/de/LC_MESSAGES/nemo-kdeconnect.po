#: src/nemo-kdeconnect.py:255
msgid "KDE Connect: {device_name}"
msgstr "KDE Connect: {device_name}"

#: src/nemo-kdeconnect.py:373
msgid "Sending to {device_name}..."
msgstr "Sende zu {device_name}..."

#: src/nemo-kdeconnect.py:374
msgid "Sending {num_files} file(s) to device"
msgstr "Sende {num_files} Datei(en) an Gerät"

#: src/nemo-kdeconnect.py:379
msgid "Could not send files"
msgstr "Dateien konnten nicht gesendet werden"

#: src/nemo-kdeconnect.py:380 src/nemo-kdeconnect.py:411 src/nemo-kdeconnect.py:442 src/nemo-kdeconnect.py:462
msgid "KDE Connect reported: {error_message}"
msgstr "KDE Connect meldet: {error_message}"

#: src/nemo-kdeconnect.py:392 src/nemo-kdeconnect.py:423
msgid "Unknown SFTP mount error"
msgstr "Unbekannter SFTP-Einhängefehler"

#: src/nemo-kdeconnect.py:394 src/nemo-kdeconnect.py:425
msgid "Could not mount {device_name}"
msgstr "{device_name} konnte nicht eingehängt werden"

#: src/nemo-kdeconnect.py:404
msgid "Phone storage opened"
msgstr "Telefonspeicher geöffnet"

#: src/nemo-kdeconnect.py:405
msgid "{device_name} is available like a disk in Nemo"
msgstr "{device_name} ist in Nemo wie ein Laufwerk verfügbar"

#: src/nemo-kdeconnect.py:410
msgid "Could not open phone storage"
msgstr "Telefonspeicher konnte nicht geöffnet werden"

#: src/nemo-kdeconnect.py:434
msgid "Phone storage mounted"
msgstr "Telefonspeicher eingehängt"

#: src/nemo-kdeconnect.py:435
msgid "{device_name} is now available in Nemo sidebar"
msgstr "{device_name} ist jetzt in der Nemo-Seitenleiste verfügbar"

#: src/nemo-kdeconnect.py:441
msgid "Could not mount phone storage"
msgstr "Telefonspeicher konnte nicht eingehängt werden"

#: src/nemo-kdeconnect.py:455
msgid "Phone storage unmounted"
msgstr "Telefonspeicher ausgehängt"

#: src/nemo-kdeconnect.py:456
msgid "{device_name} is no longer mounted"
msgstr "{device_name} ist nicht mehr eingehängt"

#: src/nemo-kdeconnect.py:461
msgid "Could not unmount phone storage"
msgstr "Telefonspeicher konnte nicht ausgehängt werden"

#: src/nemo-kdeconnect.py:520
msgid "No compatible KDE Connect devices are currently available"
msgstr "Derzeit sind keine kompatiblen KDE-Connect-Geräte verfügbar"

#: src/nemo-kdeconnect.py:552
msgid "Actions for {device_name}"
msgstr "Aktionen für {device_name}"

#: src/nemo-kdeconnect.py:562
msgid "Send selected files"
msgstr "Ausgewählte Dateien senden"

#: src/nemo-kdeconnect.py:563
msgid "Send selected files to {device_name}"
msgstr "Ausgewählte Dateien an {device_name} senden"

#: src/nemo-kdeconnect.py:572
msgid "Browse phone storage"
msgstr "Telefonspeicher durchsuchen"

#: src/nemo-kdeconnect.py:573
msgid "Mount and open {device_name} storage"
msgstr "{device_name}-Speicher einhängen und öffnen"

#: src/nemo-kdeconnect.py:582
msgid "Unmount phone storage"
msgstr "Telefonspeicher aushängen"

#: src/nemo-kdeconnect.py:583
msgid "Unmount {device_name} storage"
msgstr "{device_name}-Speicher aushängen"

#: src/nemo-kdeconnect.py:590
msgid "Mount phone storage"
msgstr "Telefonspeicher einhängen"

#: src/nemo-kdeconnect.py:591
msgid "Mount {device_name} storage for disk-like access"
msgstr "{device_name}-Speicher für laufwerkähnlichen Zugriff einhängen"

#: src/nemo-kdeconnect.py:605
msgid "No matching KDE Connect actions are available for this selection"
msgstr "Für diese Auswahl sind keine passenden KDE-Connect-Aktionen verfügbar"

#: src/nemo-kdeconnect.py:615 src/nemo-kdeconnect.py:624
msgid "KDE Connect"
msgstr "KDE Connect"

#: src/nemo-kdeconnect.py:616
msgid "Share files and browse phone storage via KDE Connect"
msgstr "Dateien teilen und Telefonspeicher über KDE Connect durchsuchen"

#: src/nemo-kdeconnect.py:625
msgid "Browse and mount phone storage via KDE Connect"
msgstr "Telefonspeicher über KDE Connect durchsuchen und einhängen"

#: src/nemo-kdeconnect.py:631
msgid "Share files and browse mounted phone storage via KDE Connect directly from within Nemo."
msgstr "Dateien teilen und eingehängten Telefonspeicher via KDE Connect direkt in Nemo durchsuchen."
